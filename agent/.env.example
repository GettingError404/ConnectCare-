# VoiceOS Environment Configuration
# Copy to .env and fill in your values

# ─── Wake Word ────────────────────────────────────────────────
WAKE_WORD_KEYWORD=hey assistant
WAKE_WORD_ENGINE=energy          # energy | porcupine
WAKE_WORD_SENSITIVITY=0.5
PORCUPINE_ACCESS_KEY=            # Get free key at picovoice.ai

# ─── Speech-to-Text ───────────────────────────────────────────
STT_ENGINE=vosk                  # vosk | whisper
VOSK_MODEL_DIR=./models/vosk     # Download from alphacephei.com/vosk/models
WHISPER_MODEL=base               # tiny|base|small|medium|large

# ─── Language ─────────────────────────────────────────────────
DEFAULT_LANGUAGE=en
LANG_DETECT_ENGINE=auto          # auto selects best available

# ─── Translation ──────────────────────────────────────────────
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_API_KEY=          # Optional for self-hosted

# ─── NLP ──────────────────────────────────────────────────────
RASA_URL=http://localhost:5005
RASA_CONFIDENCE_THRESHOLD=0.70
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2            # or mistral, phi3, etc.

# ─── Sentiment ────────────────────────────────────────────────
SENTIMENT_BACKEND=vader          # vader | transformers
USE_TRANSFORMER_SENTIMENT=false

# ─── TTS ──────────────────────────────────────────────────────
TTS_BACKEND=auto                 # auto | coqui | pyttsx3 | gtts | espeak
PREFER_COQUI_TTS=false          # Set true if TTS package is installed
TTS_SPEECH_RATE=175
TTS_VOLUME=1.0

# ─── Skills / Actions ─────────────────────────────────────────
NEWSAPI_KEY=                     # newsapi.org — free tier available
OPENWEATHER_KEY=                 # openweathermap.org — free tier
SPOTIFY_CLIENT_ID=               # Optional: for Spotify integration
SPOTIFY_CLIENT_SECRET=           # Optional
HOME_ASSISTANT_URL=              # e.g. http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=            # Long-lived access token

# ─── API Server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
DEBUG=false
